@{
    ViewData["Title"] = "Join Lobby";
    var prefilledPin = ViewBag.Pin as string ?? string.Empty;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 420px; border-radius: 20px; background: #f8f9fa;">
        <div class="text-center mb-4">
            <h1 class="display-6 fw-bold text-primary">Quiz Lobby</h1>
            <p class="text-muted mb-0">PIN kodunu ve oyuncu adini gir, host baslatinca herkes ayni anda quize girsin.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="mb-3">
            <input type="text" id="pinInput" class="form-control form-control-lg text-center fw-bold"
                   value="@prefilledPin" placeholder="GAME PIN" maxlength="6"
                   style="letter-spacing: 5px; font-size: 1.8rem; border: 2px solid #0d6efd;">
        </div>

        <div class="mb-4">
            <input type="text" id="nameInput" class="form-control form-control-lg"
                   placeholder="Oyuncu Adi" maxlength="20">
        </div>

        <button id="btnJoin" class="btn btn-primary btn-lg w-100 fw-bold py-3 shadow">Odaya Katil</button>

        <div id="statusMessage" class="mt-3 text-center d-none">
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <span class="ms-2">Lobiye baglaniliyor...</span>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/quizHub")
            .withAutomaticReconnect()
            .build();

        async function ensureConnectionStarted() {
            if (connection.state === signalR.HubConnectionState.Disconnected) {
                await connection.start();
            }
        }

        document.getElementById("btnJoin").addEventListener("click", async function () {
            const pin = document.getElementById("pinInput").value.trim();
            const name = document.getElementById("nameInput").value.trim();
            const status = document.getElementById("statusMessage");

            if (!pin || !name) {
                alert("PIN ve oyuncu adi gerekli.");
                return;
            }

            status.classList.remove("d-none");

            try {
                await ensureConnectionStarted();
                await connection.invoke("JoinLobby", pin, name, false);
                window.location.href = `/Lobby/PlayerWaiting?pin=${encodeURIComponent(pin)}&name=${encodeURIComponent(name)}`;
            } catch (error) {
                alert(error.toString().replace("Error: ", ""));
                status.classList.add("d-none");
            }
        });
    </script>
}
