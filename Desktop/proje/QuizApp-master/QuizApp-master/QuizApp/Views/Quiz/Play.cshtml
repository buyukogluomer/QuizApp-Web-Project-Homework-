@model QuizApp.Models.Questions

@{
    ViewData["Title"] = "Quiz Session";
    var score = ViewBag.Score ?? 0;
    var correctAnswers = ViewBag.CorrectAnswers ?? 0;
    var totalProcessed = ViewBag.TotalProcessed ?? 0;
    var pin = ViewBag.Pin as string;
    var playerName = ViewBag.PlayerName as string;
    var timeLimit = 10;
    string? imageUrl = Model.ImageUrl;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white p-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h3 class="mb-0">Question</h3>
                    <div class="text-end">
                        <div class="fw-semibold">Skor: @score</div>
                        <div class="small">Dogru: @correctAnswers</div>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrWhiteSpace(playerName))
                    {
                        <div class="badge bg-light text-dark mb-3">@playerName</div>
                    }

                    <h4 class="mb-4 fw-bold">@Model.Text</h4>

                    @if (!string.IsNullOrWhiteSpace(imageUrl))
                    {
                        <div class="mb-4 text-center">
                            <img src="@imageUrl" alt="Question image" class="img-fluid rounded-4 border shadow-sm" style="max-height: 320px; object-fit: cover;" />
                        </div>
                    }

                    <form asp-action="Play" method="post" id="quizForm">
                        <input type="hidden" name="questionId" value="@Model.QuestionId" />
                        <input type="hidden" name="score" value="@score" />
                        <input type="hidden" name="correctAnswers" value="@correctAnswers" />
                        <input type="hidden" name="totalProcessed" value="@totalProcessed" />
                        <input type="hidden" name="pin" value="@pin" />
                        <input type="hidden" name="playerName" value="@playerName" />
                        <input type="hidden" id="remainingSeconds" name="remainingSeconds" value="@timeLimit" />

                        <div class="list-group mb-4">
                            @for (int i = 0; i < Model.Answers.Count; i++)
                            {
                                var answer = Model.Answers[i];
                                <label class="quiz-answer list-group-item list-group-item-action d-flex align-items-center py-3 border-2 rounded-3 mb-2"
                                       data-correct="@(answer.IsCorrect ? "true" : "false")">
                                    <input class="form-check-input me-3"
                                           type="radio"
                                           name="selectedAnswerId"
                                           value="@answer.Id">
                                    <span class="quiz-answer-letter badge bg-dark me-3">@((char)('A' + i))</span>
                                    <span class="fs-5">@answer.AnswerText</span>
                                </label>
                            }
                        </div>

                        <div class="alert alert-secondary">
                            <div><strong>Hizli cevap</strong>: `@Model.Points + kalan saniye` kadar puan.</div>
                            <div><strong>Yanlis veya bos cevap</strong>: `-@(Math.Max(5, Model.Points / 2))` puan.</div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center border-top pt-4 flex-wrap gap-3">
                            <span id="timer-text" class="text-danger fw-bold fs-5">
                                <i class="far fa-clock"></i> Sure: @timeLimit saniye
                            </span>
                            <button type="submit" id="nextButton" class="btn btn-success btn-lg px-5 shadow-sm fw-bold">
                                Sonraki Soru
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .quiz-answer {
            transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
        }

        .quiz-answer:hover {
            transform: translateY(-1px);
        }

        .quiz-answer.is-locked {
            pointer-events: none;
            cursor: default;
        }

        .quiz-answer.is-correct {
            border-color: rgba(49, 208, 170, 0.95) !important;
            background: linear-gradient(135deg, rgba(49, 208, 170, 0.22), rgba(25, 116, 98, 0.22)) !important;
            box-shadow: 0 0 0 1px rgba(49, 208, 170, 0.35), 0 18px 30px rgba(12, 48, 42, 0.28);
        }

        .quiz-answer.is-wrong {
            border-color: rgba(255, 89, 110, 0.95) !important;
            background: linear-gradient(135deg, rgba(255, 89, 110, 0.20), rgba(126, 30, 47, 0.22)) !important;
            box-shadow: 0 0 0 1px rgba(255, 89, 110, 0.35), 0 18px 30px rgba(59, 18, 25, 0.28);
        }

        .quiz-answer.is-correct .quiz-answer-letter {
            background: #31d0aa !important;
            color: #05231d !important;
        }

        .quiz-answer.is-wrong .quiz-answer-letter {
            background: #ff596e !important;
            color: #fff !important;
        }
    </style>

    <script>
        let timeLeft = @timeLimit;
        const timerElement = document.getElementById("timer-text");
        const quizForm = document.getElementById("quizForm");
        const remainingInput = document.getElementById("remainingSeconds");
        const nextButton = document.getElementById("nextButton");
        const answerInputs = Array.from(document.querySelectorAll('input[name="selectedAnswerId"]'));
        const answerLabels = Array.from(document.querySelectorAll('.quiz-answer'));
        let isLocked = false;

        const countdown = setInterval(() => {
            timeLeft--;
            remainingInput.value = Math.max(timeLeft, 0);

            if (timerElement) {
                timerElement.innerHTML = `<i class="far fa-clock"></i> Sure: ${Math.max(timeLeft, 0)} saniye`;
            }

            if (timeLeft <= 0) {
                clearInterval(countdown);
                quizForm.submit();
            }
        }, 1000);

        function lockAnswers() {
            isLocked = true;
            answerLabels.forEach(label => label.classList.add("is-locked"));
            nextButton.disabled = true;
        }

        function revealAnswers(selectedInput) {
            answerLabels.forEach(label => {
                const isCorrect = label.dataset.correct === "true";
                const input = label.querySelector('input[name="selectedAnswerId"]');

                label.classList.remove("is-correct", "is-wrong");

                if (isCorrect) {
                    label.classList.add("is-correct");
                }

                if (selectedInput && input === selectedInput && !isCorrect) {
                    label.classList.add("is-wrong");
                }
            });
        }

        answerInputs.forEach(input => {
            input.addEventListener("change", function () {
                if (isLocked) {
                    return;
                }

                remainingInput.value = Math.max(timeLeft, 0);
                clearInterval(countdown);
                lockAnswers();
                revealAnswers(input);

                window.setTimeout(() => {
                    quizForm.submit();
                }, 900);
            });
        });

        quizForm.addEventListener("submit", function (event) {
            if (isLocked && event.submitter !== nextButton) {
                return;
            }

            remainingInput.value = Math.max(timeLeft, 0);
            clearInterval(countdown);

            if (isLocked) {
                return;
            }

            lockAnswers();
            revealAnswers(answerInputs.find(input => input.checked) ?? null);
        });
    </script>
}
